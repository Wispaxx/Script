local function CreateGradient(parent)
    local g = Instance.new("UIGradient", parent)
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Theme.Accent2),
        ColorSequenceKeypoint.new(1, Theme.Accent2)
    }
    g.Rotation = 45
    return g
end

local function ApplyViewportUIScale(targetFrame)
    if not targetFrame then return end
    if not IS_MOBILE then return end
    local existing = targetFrame:FindFirstChildOfClass("UIScale")
    if existing then existing:Destroy() end
    local sc = Instance.new("UIScale")
    sc.Parent = targetFrame
    SharedState.MobileScaleObjects[targetFrame] = sc
    if SharedState.RefreshMobileScale then
        SharedState.RefreshMobileScale()
    else
        sc.Scale = math.clamp(tonumber(Config.MobileGuiScale) or 0.5, 0, 1)
    end
end

SharedState.RefreshMobileScale = function()
    local s = math.clamp(tonumber(Config.MobileGuiScale) or 0.5, 0, 1)
    for frame, sc in pairs(SharedState.MobileScaleObjects) do
        if frame and frame.Parent and sc and sc.Parent == frame then
            sc.Scale = s
        else
            SharedState.MobileScaleObjects[frame] = nil
        end
    end
end

-- ====== INFINITE JUMP ======
local infiniteJumpEnabled = Config.InfiniteJump or false
local infJumpConnection = nil
local infJumpDebounce = false

local function setInfiniteJump(enabled)
    infiniteJumpEnabled = enabled
    Config.InfiniteJump = enabled
    SaveConfig()
    if infJumpConnection then
        infJumpConnection:Disconnect()
        infJumpConnection = nil
    end
    if not enabled then return end
    infJumpConnection = UserInputService.JumpRequest:Connect(function()
        if not infJumpDebounce then
            infJumpDebounce = true
            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildWhichIsA("Humanoid")
                if hum then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
            task.wait()
            infJumpDebounce = false
        end
    end)
end

if Config.InfiniteJump then
    task.spawn(function() setInfiniteJump(true) end)
end

-- ====== NOCLIP ======
local noclipEnabled = Config.Noclip or false
local noclipConnection = nil
local Clip = true

local function setNoclip(enabled)
    noclipEnabled = enabled
    Config.Noclip = enabled
    SaveConfig()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    Clip = not enabled
    if not enabled then
        local char = LocalPlayer.Character
        if char then
            for _, child in pairs(char:GetDescendants()) do
                if child:IsA("BasePart") then
                    child.CanCollide = true
                end
            end
        end
        return
    end
    noclipConnection = RunService.Stepped:Connect(function()
        if not Clip then
            local char = LocalPlayer.Character
            if char then
                for _, child in pairs(char:GetDescendants()) do
                    if child:IsA("BasePart") and child.CanCollide == true then
                        child.CanCollide = false
                    end
                end
            end
        end
    end)
end

if Config.Noclip then
    task.spawn(function() setNoclip(true) end)
end

-- ====== ESP ======
local espEnabled = Config.Esp or false
local CoreGui = game:GetService("CoreGui")

local function roundHp(hp)
    return math.floor(hp + 0.5)
end

local function espColor(plr)
    return plr.TeamColor.Color
end

local function ESP(plr)
    task.spawn(function()
        for _, v in pairs(CoreGui:GetChildren()) do
            if v.Name == plr.Name .. "_ESP_DB" then v:Destroy() end
        end
        task.wait()
        if not plr.Character or plr.Name == LocalPlayer.Name then return end
        if CoreGui:FindFirstChild(plr.Name .. "_ESP_DB") then return end

        local ESPholder = Instance.new("Folder")
        ESPholder.Name = plr.Name .. "_ESP_DB"
        ESPholder.Parent = CoreGui

        repeat task.wait(0.5) until plr.Character
            and plr.Character:FindFirstChildOfClass("Humanoid")
            and plr.Character:FindFirstChild("Head")

        local char = plr.Character
        if not char then ESPholder:Destroy() return end

        local hl = Instance.new("Highlight")
        hl.Name = "HL_" .. plr.Name
        hl.Adornee = char
        hl.FillColor = espColor(plr)
        hl.FillTransparency = 0.65
        hl.OutlineColor = espColor(plr)
        hl.OutlineTransparency = 0.65
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = ESPholder

        local billboard = Instance.new("BillboardGui")
        billboard.Adornee = char:FindFirstChild("Head")
        billboard.Name = "BB_" .. plr.Name
        billboard.Parent = ESPholder
        billboard.Size = UDim2.new(0, 100, 0, 44)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true

        local lbl = Instance.new("TextLabel")
        lbl.Parent = billboard
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Font = Enum.Font.SourceSansSemibold
        lbl.TextSize = 14
        lbl.TextColor3 = Color3.new(1, 1, 1)
        lbl.TextStrokeTransparency = 0
        lbl.TextWrapped = true
        lbl.Text = plr.Name

        local loopConn, addedConn, teamConn

        local function stopESP()
            if loopConn then loopConn:Disconnect() end
            if addedConn then addedConn:Disconnect() end
            if teamConn then teamConn:Disconnect() end
            if ESPholder and ESPholder.Parent then ESPholder:Destroy() end
        end

        local function restartESP()
            stopESP()
            if espEnabled then
                task.wait(0.5)
                ESP(plr)
            end
        end

        addedConn = plr.CharacterAdded:Connect(restartESP)
        teamConn  = plr:GetPropertyChangedSignal("TeamColor"):Connect(restartESP)

        loopConn = RunService.RenderStepped:Connect(function()
            if not CoreGui:FindFirstChild(plr.Name .. "_ESP_DB") then
                stopESP()
                return
            end
            local c = plr.Character
            if c and c:FindFirstChildOfClass("Humanoid") then
                local hum = c:FindFirstChildOfClass("Humanoid")
                local hp = roundHp(hum.Health)
                lbl.Text = plr.Name .. "\n" .. hp
                local col = espColor(plr)
                hl.FillColor    = col
                hl.OutlineColor = col
            end
        end)
    end)
end

local function setEsp(enabled)
    espEnabled = enabled
    Config.Esp = enabled
    SaveConfig()
    for _, v in pairs(CoreGui:GetChildren()) do
        if v.Name:sub(-7) == "_ESP_DB" then v:Destroy() end
    end
    if not enabled then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            ESP(plr)
        end
    end
end

if Config.Esp then
    task.spawn(function() setEsp(true) end)
end

-- ====== DRAGGABLE ======
local function MakeDraggable(handle, target, saveKey)
    local dragging, dragInput, dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if Config.UILocked then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if saveKey and Config.Positions then
                        local parentSize = target.Parent and target.Parent.AbsoluteSize or Vector2.new(1, 1)
                        Config.Positions[saveKey] = {
                            X = target.AbsolutePosition.X / parentSize.X,
                            Y = target.AbsolutePosition.Y / parentSize.Y,
                        }
                        SaveConfig()
                    end
                end
            end)
        end
    end)

    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

