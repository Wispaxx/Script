-- ====== MOUVEMENT PANEL (ENLARGED + FLY BUTTON) ======
task.spawn(function()
    local mouvementSpeedEnabled = false
    local MOUVEMENT_SPEED = Config.MouvementSpeed or 25.5
    local mouvementConn = nil

    -- Fly variables
    local flyEnabled = Config.FlyEnabled or false
    local flyConnections = {}
    local FLY_SPEED = 3  -- fixed speed
    local flyActive = false
    local flyBodyGyro = nil
    local flyBodyVelocity = nil

    -- AZERTY mapping: physical key positions
    -- Z (avancer) -> W, Q (gauche) -> A, S (arrière) -> S, D (droite) -> D, E (haut) -> E, A (bas) -> Q
    local flyKeys = { Forward = 0, Left = 0, Back = 0, Right = 0, Up = 0, Down = 0 }
    local flyKeyDownConn = nil
    local flyKeyUpConn = nil

    -- Movement speed functions (unchanged)
    local function doDisableSpeed()
        mouvementSpeedEnabled = false
        if mouvementConn then mouvementConn:Disconnect(); mouvementConn = nil end
    end

    local function doEnableSpeed()
        mouvementSpeedEnabled = true
        if mouvementConn then mouvementConn:Disconnect(); mouvementConn = nil end
        mouvementConn = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character; if not char then return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hum or not hrp then return end
            local md = hum.MoveDirection
            if md.Magnitude > 0 then
                hrp.AssemblyLinearVelocity = Vector3.new(
                    md.X * MOUVEMENT_SPEED, hrp.AssemblyLinearVelocity.Y, md.Z * MOUVEMENT_SPEED)
            end
        end)
    end

    -- Fly implementation with AZERTY keys
    local function startFly()
        if flyActive then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end

        flyActive = true

        flyBodyGyro = Instance.new("BodyGyro")
        flyBodyGyro.P = 9e4
        flyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        flyBodyGyro.Parent = hrp

        flyBodyVelocity = Instance.new("BodyVelocity")
        flyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        flyBodyVelocity.Parent = hrp

        hum.PlatformStand = true

        -- Keyboard handlers using physical key codes
        local function onKeyDown(input, processed)
            if processed then return end
            local key = input.KeyCode
            if key == Enum.KeyCode.W then         -- Z (forward)
                flyKeys.Forward = 1
            elseif key == Enum.KeyCode.A then     -- Q (left)
                flyKeys.Left = 1
            elseif key == Enum.KeyCode.S then     -- S (back)
                flyKeys.Back = 1
            elseif key == Enum.KeyCode.D then     -- D (right)
                flyKeys.Right = 1
            elseif key == Enum.KeyCode.E then     -- E (up)
                flyKeys.Up = 1
            elseif key == Enum.KeyCode.Q then     -- A (down)
                flyKeys.Down = 1
            end
        end

        local function onKeyUp(input, processed)
            if processed then return end
            local key = input.KeyCode
            if key == Enum.KeyCode.W then
                flyKeys.Forward = 0
            elseif key == Enum.KeyCode.A then
                flyKeys.Left = 0
            elseif key == Enum.KeyCode.S then
                flyKeys.Back = 0
            elseif key == Enum.KeyCode.D then
                flyKeys.Right = 0
            elseif key == Enum.KeyCode.E then
                flyKeys.Up = 0
            elseif key == Enum.KeyCode.Q then
                flyKeys.Down = 0
            end
        end

        flyKeyDownConn = UserInputService.InputBegan:Connect(onKeyDown)
        flyKeyUpConn = UserInputService.InputEnded:Connect(onKeyUp)

        -- Movement loop
        local flyStepConn = RunService.Stepped:Connect(function()
            if not flyActive then return end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then return end

            local camera = workspace.CurrentCamera
            -- move vector: X = right-left, Y = up-down, Z = forward-back
            local move = Vector3.new(flyKeys.Right - flyKeys.Left, flyKeys.Up - flyKeys.Down, flyKeys.Forward - flyKeys.Back)
            if move.Magnitude > 0 then
                local cf = camera.CFrame
                local vel = cf.RightVector * move.X + cf.UpVector * move.Y + cf.LookVector * move.Z
                flyBodyVelocity.Velocity = vel.Unit * FLY_SPEED * 50
            else
                flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end

            flyBodyGyro.CFrame = camera.CFrame
            hum.PlatformStand = true
        end)

        flyConnections = {
            flyStepConn,
            flyKeyDownConn,
            flyKeyUpConn,
            charAddedConn = LocalPlayer.CharacterAdded:Connect(function()
                task.wait(0.5)
                if flyEnabled then startFly() end
            end)
        }
    end

    local function stopFly()
        flyActive = false
        for _, conn in pairs(flyConnections) do
            if conn then pcall(function() conn:Disconnect() end) end
        end
        flyConnections = {}
        if flyBodyGyro then flyBodyGyro:Destroy() end
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
        flyBodyGyro = nil
        flyBodyVelocity = nil

        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.PlatformStand = false end
        end
    end

    local function setFly(enabled)
        flyEnabled = enabled
        Config.FlyEnabled = enabled
        SaveConfig()
        if enabled then
            startFly()
        else
            stopFly()
        end
    end

    if Config.FlyEnabled then
        task.spawn(function() setFly(true) end)
    end

    -- GUI creation (unchanged)
    local mvGui = Instance.new("ScreenGui")
    mvGui.Name = "MouvementUI"; mvGui.ResetOnSpawn = false
    mvGui.Enabled = true
    mvGui.Parent = PlayerGui

    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        mvGui.Enabled = true
    end)

    local mobileScale = IS_MOBILE and 0.6 or 1
    local mvHeight = IS_MOBILE and 170 or (170 * mobileScale)
    local mvFrame = Instance.new("Frame")
    mvFrame.Size = UDim2.new(0, 300 * mobileScale, 0, mvHeight)
    mvFrame.Position = UDim2.new(Config.Positions.Mouvement.X, 0, Config.Positions.Mouvement.Y, 0)
    mvFrame.BackgroundColor3 = Theme.Background
    mvFrame.BackgroundTransparency = 0.05
    mvFrame.BorderSizePixel = 0
    mvFrame.Parent = mvGui
    ApplyViewportUIScale(mvFrame)
    Instance.new("UICorner", mvFrame).CornerRadius = UDim.new(0,12)
    local mvStroke = Instance.new("UIStroke", mvFrame)
    mvStroke.Color = Theme.Accent2
    mvStroke.Thickness = 1.5
    mvStroke.Transparency = 0.4
    CreateGradient(mvStroke)

    local mvDragHandle = Instance.new("Frame", mvFrame)
    mvDragHandle.Size = UDim2.new(1,0,0,38)
    mvDragHandle.BackgroundTransparency = 1
    MakeDraggable(mvDragHandle, mvFrame, "Mouvement")

    local mvTitle = Instance.new("TextLabel", mvDragHandle)
    mvTitle.Size = UDim2.new(1,-15,1,0)
    mvTitle.Position = UDim2.new(0,15,0,0)
    mvTitle.BackgroundTransparency = 1
    mvTitle.Text = GetText("MOUVEMENT")
    mvTitle.Font = Enum.Font.GothamBlack
    mvTitle.TextSize = 15
    mvTitle.TextColor3 = Theme.TextPrimary
    mvTitle.TextXAlignment = Enum.TextXAlignment.Left

    local speedReadout = Instance.new("TextLabel", mvFrame)
    speedReadout.Size = UDim2.new(0,56,0,38)
    speedReadout.Position = UDim2.new(1,-66,0,0)
    speedReadout.BackgroundTransparency = 1
    speedReadout.Text = string.format("%.1f", MOUVEMENT_SPEED)
    speedReadout.Font = Enum.Font.GothamBlack
    speedReadout.TextSize = 15
    speedReadout.TextColor3 = Theme.Accent1
    speedReadout.TextXAlignment = Enum.TextXAlignment.Right

    local SLIDER_X_PAD = 16
    local sliderBg = Instance.new("Frame", mvFrame)
    sliderBg.Size = UDim2.new(1,-SLIDER_X_PAD*2,0,6)
    sliderBg.Position = UDim2.new(0,SLIDER_X_PAD,0,46)
    sliderBg.BackgroundColor3 = Theme.SurfaceHighlight
    sliderBg.BorderSizePixel = 0
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1,0)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.BackgroundColor3 = Theme.Accent1
    sliderFill.BorderSizePixel = 0
    sliderFill.Size = UDim2.new(0,0,1,0)
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", mvFrame)
    knob.Size = UDim2.new(0,16,0,16)
    knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local knobStroke = Instance.new("UIStroke", knob)
    knobStroke.Color = Theme.Accent1
    knobStroke.Thickness = 2

    local MIN_SPEED, MAX_SPEED = 5, 100

    local function speedToT(s) return math.clamp((s-MIN_SPEED)/(MAX_SPEED-MIN_SPEED),0,1) end
    local function updateSlider(s)
        MOUVEMENT_SPEED = math.clamp(s, MIN_SPEED, MAX_SPEED)
        Config.MouvementSpeed = MOUVEMENT_SPEED
        SaveConfig()
        local t = speedToT(MOUVEMENT_SPEED)
        sliderFill.Size = UDim2.new(t,0,1,0)
        local frameW = mvFrame.AbsoluteSize.X
        local trackW = frameW - SLIDER_X_PAD*2
        local knobX = SLIDER_X_PAD + t*trackW
        knob.Position = UDim2.new(0, knobX, 0, 46+3)
        speedReadout.Text = string.format("%.1f", MOUVEMENT_SPEED)
    end

    task.defer(function() updateSlider(MOUVEMENT_SPEED) end)
    mvFrame.Changed:Connect(function(prop)
        if prop == "AbsoluteSize" then updateSlider(MOUVEMENT_SPEED) end
    end)

    local sliderDragging = false
    local function onSliderInput(pos)
        local trackLeft = sliderBg.AbsolutePosition.X
        local trackRight = trackLeft + sliderBg.AbsoluteSize.X
        local t = math.clamp((pos.X - trackLeft)/(trackRight-trackLeft), 0, 1)
        updateSlider(MIN_SPEED + t*(MAX_SPEED-MIN_SPEED))
    end

    sliderBg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true
            onSliderInput(inp.Position)
        end
    end)
    knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliderDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            onSliderInput(inp.Position)
        end
    end)

    local minLbl = Instance.new("TextLabel", mvFrame)
    minLbl.Size = UDim2.new(0,30,0,14)
    minLbl.Position = UDim2.new(0,SLIDER_X_PAD,0,55)
    minLbl.BackgroundTransparency = 1
    minLbl.Text = "5"
    minLbl.Font = Enum.Font.GothamMedium
    minLbl.TextSize = 10
    minLbl.TextColor3 = Theme.TextSecondary
    minLbl.TextXAlignment = Enum.TextXAlignment.Left

    local maxLbl = Instance.new("TextLabel", mvFrame)
    maxLbl.Size = UDim2.new(0,36,0,14)
    maxLbl.Position = UDim2.new(1,-SLIDER_X_PAD-36,0,55)
    maxLbl.BackgroundTransparency = 1
    maxLbl.Text = "100"
    maxLbl.Font = Enum.Font.GothamMedium
    maxLbl.TextSize = 10
    maxLbl.TextColor3 = Theme.TextSecondary
    maxLbl.TextXAlignment = Enum.TextXAlignment.Right

    -- Speed toggle button
    local mvBtn = Instance.new("TextButton", mvFrame)
    mvBtn.Size = UDim2.new(1,-32,0,34)
    mvBtn.Position = UDim2.new(0,16,1,-80)
    mvBtn.BackgroundColor3 = Theme.SurfaceHighlight
    mvBtn.Text = GetText("DISABLED");
    mvBtn.Font = Enum.Font.GothamBold
    mvBtn.TextSize = 13
    mvBtn.TextColor3 = Theme.TextPrimary
    Instance.new("UICorner", mvBtn).CornerRadius = UDim.new(0,8)

    local function updateSpeedBtnVisual()
        mvBtn.Text = mouvementSpeedEnabled and GetText("ENABLED") or GetText("DISABLED")
        mvBtn.BackgroundColor3 = mouvementSpeedEnabled and Theme.Success or Theme.SurfaceHighlight
    end

    mvBtn.MouseButton1Click:Connect(function()
        if mouvementSpeedEnabled then doDisableSpeed() else doEnableSpeed() end
        updateSpeedBtnVisual()
    end)

    -- Fly toggle button
    local flyBtn = Instance.new("TextButton", mvFrame)
    flyBtn.Size = UDim2.new(1,-32,0,34)
    flyBtn.Position = UDim2.new(0,16,1,-38)
    flyBtn.BackgroundColor3 = Theme.SurfaceHighlight
    flyBtn.Text = flyEnabled and (GetText("FLY") .. " : " .. GetText("ENABLED")) or (GetText("FLY") .. " : " .. GetText("DISABLED"))
    flyBtn.Font = Enum.Font.GothamBold
    flyBtn.TextSize = 13
    flyBtn.TextColor3 = Theme.TextPrimary
    Instance.new("UICorner", flyBtn).CornerRadius = UDim.new(0,8)

    local function updateFlyBtnVisual()
        flyBtn.Text = flyEnabled and "FLY : ENABLED" or "FLY : DISABLED"
        flyBtn.BackgroundColor3 = flyEnabled and Theme.Success or Theme.SurfaceHighlight
    end

    flyBtn.MouseButton1Click:Connect(function()
        setFly(not flyEnabled)
        updateFlyBtnVisual()
        ShowNotification(GetText("FLY"), flyEnabled and GetText("ENABLED") or GetText("DISABLED"))
    end)

    -- Initialise UI states
    if Config.MouvementSpeed then
        MOUVEMENT_SPEED = Config.MouvementSpeed
        updateSlider(MOUVEMENT_SPEED)
    end
    if Config.FlyEnabled then
        updateFlyBtnVisual()
    end
    updateSpeedBtnVisual()
end)
