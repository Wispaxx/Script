-- Fonction pour créer le bouton de l'arme (Rifle ou Taser)
local function CreateWeaponButton()
    -- Supprimer l'ancien bouton s'il existe
    if currentWeaponButton then
        currentWeaponButton:Destroy()
        currentWeaponButton = nil
    end
    
    local currentTeamName = LocalPlayer.Team and LocalPlayer.Team.Name or "No Team"
    local isGuard = currentTeamName == "Guards"
    local weaponKey = isGuard and "TASER" or "RIFLE"
    local weaponPath = isGuard and game.Workspace.Map.GuardsRoom.Important.TaserShelf.ItemShelfInteractive or game.Workspace.Map.Outside.StrayDogBase.Important.TakeRifleTable.RifleTake.MainPart
    
    currentWeaponButton = CreateGiveButton(gList, GetText(weaponKey), function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local savedCFrame = hrp.CFrame
        local wasNoclip = noclipEnabled

        local prompt = weaponPath:FindFirstChildOfClass("ProximityPrompt")
        if not prompt then
            ShowNotification("GIVE PANEL", "Item not found !")
            return
        end

        local targetPart = prompt.Parent

        if wasNoclip then
            setNoclip(false)
            task.wait(0.05)
        end

        hrp.CFrame = targetPart.CFrame * CFrame.new(0, 0, -1)
        task.wait(0.15)
        fireproximityprompt(prompt)
        task.wait(0.1)

        if not LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool") and not char:FindFirstChildWhichIsA("Tool") then
            hrp.CFrame = targetPart.CFrame * CFrame.new(0, 0, -0.5)
            task.wait(0.1)
            fireproximityprompt(prompt)
        end

        local waited = 0
        repeat
            task.wait(0.05)
            waited = waited + 0.05
        until LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
           or char:FindFirstChildWhichIsA("Tool")
           or waited >= 3

        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hum then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            task.wait(0.3)
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end

        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        task.wait(0.1)

        hrp.CFrame = savedCFrame * CFrame.new(0, 3, 0)
        task.wait(0.1)

        if wasNoclip then
            setNoclip(true)
        end
    end)
    
    -- Placer le bouton weapon en première position
    local otherChildren = {}
    for _, child in pairs(gList:GetChildren()) do
