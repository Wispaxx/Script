local function CreateLangButton(text, langCode)
    local btn = Instance.new("TextButton", langContainer)
    btn.Size = UDim2.new(0, 50, 0, 24)
    btn.BackgroundColor3 = Config.Language == langCode and Theme.Accent1 or Theme.SurfaceHighlight
    btn.Text = text
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 11
    btn.TextColor3 = Config.Language == langCode and Color3.fromRGB(0, 0, 0) or Theme.TextPrimary
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    btn.MouseButton1Click:Connect(function()
        Config.Language = langCode
        SaveConfig()
        
        -- Mettre à jour les couleurs des boutons
        for _, child in pairs(langContainer:GetChildren()) do
            if child:IsA("TextButton") then
                if child.Text == text then
                    child.BackgroundColor3 = Theme.Accent1
                    child.TextColor3 = Color3.fromRGB(0, 0, 0)
                else
                    child.BackgroundColor3 = Theme.SurfaceHighlight
                    child.TextColor3 = Theme.TextPrimary
                end
            end
        end
        
        ShowNotification("LANGUAGE", "Language changed to " .. text)
    end)
    
    return btn
end

